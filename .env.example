# Helius RPC — https://dev.helius.xyz/dashboard/app
SOLANA_RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_WS_ENDPOINT=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Public key of the wallet to monitor
WALLET_ADDRESS=YOUR_WALLET_PUBLIC_KEY

# Private key for signing close transactions
# Supported formats:
#   JSON byte array : [1,2,3,...,64]
#   Base58 string   : 5K... (Phantom / Solflare export)
WALLET_PRIVATE_KEY=YOUR_PRIVATE_KEY

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Default SL/TP applied to every new position (optional — comment out to disable)
# DEFAULT_SL_PERCENT=10
# DEFAULT_TP_PERCENT=15

# Close a position once either token's share of position value drops below this
# floor (independent of the entry ratio) — signals that swaps have pushed the
# active bin through most/all of the range
# DEFAULT_MIN_RATIO_A=30
# DEFAULT_MIN_RATIO_B=20

# Dry run mode — simulate transactions without sending (true/false)
DRY_RUN=true

# Telegram bot — https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your personal chat ID — send /start to @userinfobot to get it
TELEGRAM_CHAT_ID=your_chat_id_here
